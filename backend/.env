# FastAPI Backend for VMS
# Manages cameras and coordinates with MediaMTX

MEDIAMTX_API_URL=http://localhost:9997
MEDIAMTX_RTSP_PORT=8554
MEDIAMTX_WEBRTC_PORT=8889
MEDIAMTX_HLS_PORT=8888
MEDIAMTX_HOST=localhost

# Backend settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# CORS - frontend origin
FRONTEND_URL=http://localhost:5173

# Transcoding H.265 → H.264 for WebRTC
# "gstreamer" = auto-detect Jetson HW decode (nvv4l2decoder), SW encode (x264enc) on Orin
# "ffmpeg"    = FFmpeg software (libx264)
TRANSCODE_METHOD=ffmpeg
TRANSCODE_BITRATE=800000
TRANSCODE_BITRATE_MAIN=3000000
TRANSCODE_RTSP_LATENCY=200
TRANSCODE_THREADS=2
